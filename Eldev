; -*- mode: emacs-lisp; lexical-binding: t -*-

;; Autodetermined by `eldev init'.
(eldev-use-package-archive 'gnu-elpa)

(eldev-use-plugin 'autoloads)

;; Configure for automatic build/installation of the Ada grammar library.
(setq ada-ts-mode-grammar-install 'auto)

(eldev-add-loading-roots 'test "test")

;; Install `lsp-mode' for testing.
(setq package-check-signature nil)
(eldev-add-extra-dependencies 'test '(:package lsp-mode :archives (melpa-unstable gnu)))

;; Configure Linting
(setq eldev-lint-default '(doc re))

;; Configure Doctor
(when (eq system-type 'windows-nt)
  ;; Check doesn't seem to work on Windows runner
  (setq eldev-doctor-disabled-tests '(eldev-file-owners)))

;; Configure Maintainer Plugin
(setq eldev-release-allowed-branch "main")
(setq eldev-release-test-local t)
(setq eldev-release-min-version-size 3)
(setq eldev-release-post-release-commit-message "Post-release version bump."
      eldev-release-post-release-commit
      (lambda (version)
        (if (eldev-version-snapshot-p version)
            version
          (let* ((next-version (eldev-release-next-minor-version version))
                 (next-version-len (length next-version))
                 (padding (when (< next-version-len eldev-release-min-version-size)
                            (make-list (- eldev-release-min-version-size next-version-len) 0))))
            (append next-version padding (cdr (version-to-list "0snapshot")))))))
